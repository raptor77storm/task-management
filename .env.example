# API Configuration for Local Server/VM Deployment
# Copy this file to .env.local and update values for your deployment

# Backend API Base URL
# For development: http://localhost:5267/api
# For local server: http://192.168.1.100:5267/api (adjust IP and port as needed)
# Leave empty to auto-detect from current hostname
REACT_APP_API_BASE=

# Backend API Port (default: 5267)
# This is used for auto-detection if REACT_APP_API_BASE is not set
REACT_APP_API_PORT=5267
